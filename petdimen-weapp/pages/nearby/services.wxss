.page {
  background-color: #f5f5f5;
  min-height: 100vh;
}

/* 搜索栏 */
.search-section {
  background-color: #fff;
  padding: 12px 16px;
  border-bottom: 1px solid #e8e8e8;
  position: sticky;
  top: 0;
  z-index: 10;
}

.search-bar {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 8px 12px;
  background-color: #f5f5f5;
  border-radius: 6px;
  margin-bottom: 12px;
}

.search-icon {
  font-size: 16px;
  color: #999;
}

.search-input {
  flex: 1;
  background-color: transparent;
  border: none;
  font-size: 14px;
  color: #333;
}

.search-input::placeholder {
  color: #999;
}

/* 地图切换按钮 */
.map-toggle {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  padding: 8px 16px;
  background-color: #FF6B6B;
  border-radius: 20px;
  margin-top: 12px;
  color: #fff;
  font-size: 13px;
  font-weight: 500;
}

.map-icon {
  font-size: 16px;
}

.map-text {
  font-size: 13px;
}

/* 地图容器 */
.map-container {
  width: 100%;
  height: calc(100vh - 180px);
  position: relative;
}

.service-map {
  width: 100%;
  height: 100%;
}

.map-controls {
  position: absolute;
  bottom: 20px;
  right: 20px;
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.map-control-btn {
  width: 44px;
  height: 44px;
  background-color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
}

.control-icon {
  width: 24px;
  height: 24px;
}

/* 附近城市推荐 */
.nearby-city-section {
  background-color: #fff;
  margin: 12px;
  border-radius: 12px;
  padding: 16px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
}

.nearby-city-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  margin-bottom: 16px;
  padding-bottom: 16px;
  border-bottom: 1px solid #f0f0f0;
}

.nearby-city-icon {
  font-size: 48px;
}

.nearby-city-title {
  font-size: 16px;
  font-weight: 600;
  color: #333;
}

.nearby-city-subtitle {
  font-size: 12px;
  color: #999;
  text-align: center;
}

.nearby-city-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.distance-tag {
  display: inline-block;
  padding: 4px 8px;
  background-color: #FFF3E0;
  border-radius: 4px;
  font-size: 11px;
  color: #FF6B6B;
  font-weight: 600;
  margin-left: 6px;
}

/* 筛选标签 */
.filter-tabs {
  display: flex;
  gap: 8px;
  overflow-x: auto;
  padding-bottom: 4px;
}

.filter-tab {
  flex-shrink: 0;
  padding: 6px 12px;
  border-radius: 16px;
  background-color: #f0f0f0;
  color: #666;
  font-size: 13px;
  font-weight: 500;
  transition: all 0.2s;
}

.filter-tab.active {
  background-color: #FF6B6B;
  color: #fff;
}

/* 加载状态 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 60vh;
  gap: 16px;
}

.loading-spinner {
  width: 40px;
  height: 40px;
  border: 3px solid #f0f0f0;
  border-top-color: #FF6B6B;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  font-size: 14px;
  color: #999;
}

/* 服务容器 */
.services-container {
  padding: 12px 0;
}

/* 服务卡片 */
.service-card {
  background-color: #fff;
  margin: 12px 12px;
  border-radius: 12px;
  overflow: hidden;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
  display: flex;
  flex-direction: column;
}

.service-image {
  width: 100%;
  height: 180px;
  object-fit: cover;
}

.service-info {
  padding: 12px;
  display: flex;
  flex-direction: column;
  gap: 8px;
}

/* 服务头部 */
.service-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 8px;
}

.service-name {
  font-size: 16px;
  font-weight: 600;
  color: #333;
  flex: 1;
}

.service-rating {
  display: flex;
  align-items: center;
  gap: 4px;
  flex-shrink: 0;
}

.rating-stars {
  font-size: 12px;
  color: #FF6B6B;
  font-weight: 600;
}

.rating-count {
  font-size: 11px;
  color: #999;
}

/* 服务类型 */
.service-type {
  display: flex;
  gap: 6px;
}

.type-tag {
  display: inline-block;
  padding: 4px 8px;
  background-color: #f0f0f0;
  border-radius: 4px;
  font-size: 11px;
  color: #666;
}

/* 服务描述 */
.service-desc {
  font-size: 13px;
  color: #666;
  line-height: 1.5;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

/* 位置信息 */
.service-location {
  display: flex;
  align-items: center;
  gap: 4px;
  font-size: 12px;
  color: #999;
}

.location-icon {
  font-size: 12px;
}

.location-text {
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.distance {
  flex-shrink: 0;
  color: #FF6B6B;
  font-weight: 600;
}

/* 服务时间 */
.service-hours {
  display: flex;
  align-items: center;
  gap: 4px;
  font-size: 12px;
  color: #999;
}

.hours-icon {
  font-size: 12px;
}

.hours-text {
  flex: 1;
}

/* 操作按钮 */
.service-actions {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 8px;
  margin-top: 8px;
}

.action-btn {
  padding: 8px 12px;
  background-color: #f9f9f9;
  border: 1px solid #e8e8e8;
  border-radius: 6px;
  font-size: 12px;
  font-weight: 500;
  color: #666;
  transition: all 0.2s;
  height: auto;
  line-height: 1;
}

.action-btn:active {
  background-color: #f0f0f0;
}

.call-btn:active {
  background-color: #FF6B6B;
  border-color: #FF6B6B;
  color: #fff;
}

.map-btn:active {
  background-color: #4ECDC4;
  border-color: #4ECDC4;
  color: #fff;
}

.share-btn:active {
  background-color: #95DE64;
  border-color: #95DE64;
  color: #fff;
}

/* 加载更多 */
.load-more {
  display: flex;
  justify-content: center;
  padding: 20px 16px;
}

.load-more-btn {
  padding: 10px 32px;
  background-color: #fff;
  border: 1px solid #e8e8e8;
  border-radius: 6px;
  font-size: 14px;
  font-weight: 500;
  color: #666;
  height: auto;
  line-height: 1;
}

/* 没有更多 */
.no-more {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 20px 16px;
  color: #999;
  font-size: 12px;
}

/* 空状态 */
.empty-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 60vh;
  gap: 12px;
}

.empty-icon {
  font-size: 64px;
  margin-bottom: 16px;
}

.empty-text {
  font-size: 16px;
  font-weight: 600;
  color: #333;
}

.empty-subtitle {
  font-size: 13px;
  color: #999;
}
