<view class="login-container">
  <!-- 标题 -->
  <view class="login-header">
    <text class="app-title">PetDimen</text>
    <text class="app-subtitle">宠物生活助手</text>
  </view>

  <!-- 标签页切换 -->
  <view class="tab-container">
    <view class="tab-item {{activeTab === 'wechat' ? 'active' : ''}}" bindtap="switchTab" data-tab="wechat">
      <text>微信登录</text>
    </view>
    <view class="tab-item {{activeTab === 'account' ? 'active' : ''}}" bindtap="switchTab" data-tab="account">
      <text>账号登录</text>
    </view>
  </view>

  <!-- 微信登录标签页 -->
  <view class="tab-content {{activeTab === 'wechat' ? 'active' : ''}}">
    <view class="wechat-login">
      <view class="wechat-icon">🔐</view>
      <text class="wechat-title">微信登录</text>
      <text class="wechat-desc">使用微信账号快速登录</text>
      
      <button 
        class="btn btn-primary btn-large"
        open-type="getPhoneNumber"
        bindgetphonenumber="handleGetPhoneNumber"
        wx:if="{{!wechatLoginLoading}}"
      >
        获取手机号并登录
      </button>
      
      <button 
        class="btn btn-primary btn-large loading"
        disabled
        wx:if="{{wechatLoginLoading}}"
      >
        登录中...
      </button>

      <view class="wechat-tips">
        <text class="tips-title">⚠️ 微信登录失败？</text>
        <text class="tips-text">如果微信登录失败，请使用下方的账号登录功能</text>
      </view>
    </view>
  </view>

  <!-- 账号登录标签页 -->
  <view class="tab-content {{activeTab === 'account' ? 'active' : ''}}">
    <view class="account-login">
      <!-- 登录表单 -->
      <view class="form-group">
        <label class="form-label">用户名</label>
        <input 
          class="form-input"
          type="text"
          placeholder="请输入用户名"
          value="{{username}}"
          bindinput="handleUsernameInput"
          disabled="{{accountLoginLoading}}"
        />
      </view>

      <view class="form-group">
        <label class="form-label">密码</label>
        <input 
          class="form-input"
          type="password"
          placeholder="请输入密码"
          value="{{password}}"
          bindinput="handlePasswordInput"
          disabled="{{accountLoginLoading}}"
        />
      </view>

      <!-- 登录按钮 -->
      <button 
        class="btn btn-primary btn-large"
        bindtap="handleAccountLogin"
        wx:if="{{!accountLoginLoading}}"
      >
        登录
      </button>

      <button 
        class="btn btn-primary btn-large loading"
        disabled
        wx:if="{{accountLoginLoading}}"
      >
        登录中...
      </button>

      <!-- 注册链接 -->
      <view class="register-link">
        <text>还没有账号？</text>
        <text class="link" bindtap="navigateToRegister">立即注册</text>
      </view>

      <!-- 错误提示 -->
      <view class="error-message" wx:if="{{accountError}}">
        <text>{{accountError}}</text>
      </view>
    </view>
  </view>

  <!-- 加载指示器 -->
  <view class="loading-overlay" wx:if="{{showLoading}}">
    <view class="loading-spinner"></view>
    <text>{{loadingText}}</text>
  </view>
</view>
