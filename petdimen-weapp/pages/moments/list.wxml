<view class="page">
  <!-- 页面头部 -->
  <view class="page-header">
    <view class="header-top">
      <text class="page-title">动态</text>
      <button class="publish-btn" bindtap="goPublish">发布</button>
    </view>
    
    <!-- 筛选标签 -->
    <view class="filter-tabs">
      <view class="filter-tab {{activeFilter === 'all' ? 'active' : ''}}" bindtap="filterMoments" data-filter="all">
        全部
      </view>
      <view class="filter-tab {{activeFilter === 'following' ? 'active' : ''}}" bindtap="filterMoments" data-filter="following">
        关注
      </view>
      <view class="filter-tab {{activeFilter === 'nearby' ? 'active' : ''}}" bindtap="filterMoments" data-filter="nearby">
        附近
      </view>
    </view>
  </view>

  <!-- 加载状态 -->
  <view wx:if="{{loading && moments.length === 0}}" class="loading-container">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 动态列表 -->
  <view wx:if="{{!loading || moments.length > 0}}" class="moments-container">
    <view wx:for="{{moments}}" wx:key="id" class="moment-card">
      <!-- 用户信息 -->
      <view class="moment-header">
        <image src="{{item.userAvatar}}" class="user-avatar" />
        <view class="user-info">
          <text class="user-name">{{item.userName}}</text>
          <text class="moment-time">{{item.createdAt}}</text>
        </view>
        <view class="moment-menu" bindtap="showMomentMenu" data-id="{{item.id}}">
          ⋮
        </view>
      </view>

      <!-- 动态内容 -->
      <view class="moment-content">
        <text class="moment-text">{{item.content}}</text>
      </view>

      <!-- 媒体内容 -->
      <view wx:if="{{item.media && item.media.length > 0}}" class="moment-media">
        <view wx:if="{{item.media.length === 1}}" class="media-single">
          <image src="{{item.media[0].url}}" mode="aspectFill" bindtap="previewImage" data-url="{{item.media[0].url}}" />
        </view>
        <view wx:else class="media-grid">
          <view wx:for="{{item.media}}" wx:key="url" class="media-item">
            <image src="{{item.url}}" mode="aspectFill" bindtap="previewImage" data-url="{{item.url}}" />
          </view>
        </view>
      </view>

      <!-- 宠物标签 -->
      <view wx:if="{{item.petTags && item.petTags.length > 0}}" class="pet-tags">
        <view wx:for="{{item.petTags}}" wx:key="id" class="pet-tag">
          {{item.name}}
        </view>
      </view>

      <!-- 位置信息 -->
      <view wx:if="{{item.location}}" class="moment-location">
        <text class="location-icon">📍</text>
        <text class="location-text">{{item.location}}</text>
      </view>

      <!-- 互动信息 -->
      <view class="moment-stats">
        <text class="stat-item">👍 {{item.likeCount}}</text>
        <text class="stat-item">💬 {{item.commentCount}}</text>
        <text class="stat-item">👁 {{item.viewCount}}</text>
      </view>

      <!-- 操作按钮 -->
      <view class="moment-actions">
        <button class="action-btn {{item.liked ? 'liked' : ''}}" bindtap="toggleLike" data-id="{{item.id}}">
          {{item.liked ? '👍 已赞' : '👍 赞'}}
        </button>
        <button class="action-btn" bindtap="goComment" data-id="{{item.id}}">
          💬 评论
        </button>
        <button class="action-btn" bindtap="shareMoment" data-id="{{item.id}}">
          🔗 分享
        </button>
      </view>
    </view>

    <!-- 加载更多 -->
    <view wx:if="{{hasMore}}" class="load-more">
      <button class="load-more-btn" bindtap="loadMore" loading="{{loadingMore}}">
        加载更多
      </button>
    </view>

    <!-- 没有更多 -->
    <view wx:if="{{!hasMore && moments.length > 0}}" class="no-more">
      <text>没有更多动态了</text>
    </view>
  </view>

  <!-- 空状态 -->
  <view wx:if="{{!loading && moments.length === 0}}" class="empty-container">
    <text class="empty-icon">📸</text>
    <text class="empty-text">暂无动态</text>
    <text class="empty-subtitle">分享您和宠物的精彩时刻</text>
    <button class="btn btn-primary" bindtap="goPublish">发布动态</button>
  </view>
</view>
