.page {
  background-color: #f5f5f5;
  min-height: 100vh;
}

.container {
  padding: 16px;
}

/* 页面头部 */
.page-header {
  margin-bottom: 24px;
}

.page-title {
  display: block;
  font-size: 24px;
  font-weight: 600;
  color: #333;
}

/* 区域 */
.section {
  background-color: #fff;
  border-radius: 12px;
  padding: 16px;
  margin-bottom: 16px;
}

.section-title {
  display: block;
  font-size: 14px;
  font-weight: 600;
  color: #333;
  margin-bottom: 12px;
}

/* 内容输入 */
.content-input {
  width: 100%;
  padding: 12px;
  border: 1px solid #e8e8e8;
  border-radius: 8px;
  font-size: 14px;
  color: #333;
  background-color: #fff;
  min-height: 120px;
  box-sizing: border-box;
  resize: vertical;
}

.content-input:focus {
  border-color: #FF6B6B;
  outline: none;
}

.content-input::placeholder {
  color: #999;
}

.input-count {
  font-size: 12px;
  color: #999;
  text-align: right;
  margin-top: 4px;
}

/* 媒体上传 */
.media-upload {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12px;
}

.media-item {
  position: relative;
  width: 100%;
  aspect-ratio: 1;
  border-radius: 8px;
  overflow: hidden;
}

.media-item image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.media-delete {
  position: absolute;
  top: 4px;
  right: 4px;
  width: 24px;
  height: 24px;
  background-color: rgba(0, 0, 0, 0.6);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16px;
  font-weight: bold;
}

.media-add {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 2px dashed #e8e8e8;
  border-radius: 8px;
  background-color: #f9f9f9;
  gap: 8px;
  transition: all 0.2s;
}

.media-add:active {
  background-color: #f0f0f0;
  border-color: #FF6B6B;
}

.media-icon {
  font-size: 28px;
}

.media-text {
  font-size: 12px;
  color: #999;
}

/* 宠物选择器 */
.pet-selector {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12px;
}

.pet-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 12px;
  border: 2px solid #e8e8e8;
  border-radius: 8px;
  background-color: #f9f9f9;
  gap: 8px;
  transition: all 0.2s;
}

.pet-item:active {
  background-color: #f0f0f0;
}

.pet-item.selected {
  background-color: #FF6B6B;
  border-color: #FF6B6B;
}

.pet-avatar {
  width: 48px;
  height: 48px;
  border-radius: 50%;
  object-fit: cover;
}

.pet-name {
  font-size: 12px;
  font-weight: 500;
  color: #333;
  text-align: center;
}

.pet-item.selected .pet-name {
  color: #fff;
}

/* 位置输入 */
.location-input {
  display: flex;
  align-items: center;
  padding: 12px;
  border: 1px solid #e8e8e8;
  border-radius: 8px;
  background-color: #f9f9f9;
  gap: 12px;
}

.location-icon {
  font-size: 20px;
}

.location-text {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.location-main {
  font-size: 14px;
  color: #333;
  font-weight: 500;
}

.location-main.placeholder {
  color: #999;
}

.location-arrow {
  font-size: 16px;
  color: #999;
}

/* 隐私设置 */
.privacy-options {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.privacy-item {
  display: flex;
  align-items: center;
  padding: 12px;
  border: 1px solid #e8e8e8;
  border-radius: 8px;
  background-color: #f9f9f9;
  gap: 12px;
  transition: all 0.2s;
}

.privacy-item:active {
  background-color: #f0f0f0;
}

.privacy-item.selected {
  background-color: #fff;
  border-color: #FF6B6B;
}

.radio {
  width: 20px;
  height: 20px;
  border: 2px solid #e8e8e8;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: all 0.2s;
}

.radio.checked {
  background-color: #FF6B6B;
  border-color: #FF6B6B;
}

.radio.checked::after {
  content: '';
  width: 6px;
  height: 6px;
  background-color: #fff;
  border-radius: 50%;
}

.privacy-label {
  font-size: 14px;
  color: #333;
  font-weight: 500;
}

/* 按钮 */
.form-actions {
  display: flex;
  flex-direction: column;
  gap: 12px;
  margin-top: 24px;
}

.btn {
  padding: 12px 16px;
  border: none;
  border-radius: 6px;
  font-size: 14px;
  font-weight: 500;
  transition: all 0.2s;
}

.btn-primary {
  background-color: #FF6B6B;
  color: #fff;
}

.btn-primary:active {
  opacity: 0.8;
}

.btn-outline {
  background-color: #fff;
  border: 1px solid #e8e8e8;
  color: #333;
}

.btn-outline:active {
  background-color: #f5f5f5;
}

.btn-block {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}
