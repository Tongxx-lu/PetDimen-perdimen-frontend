.page {
  background-color: #f5f5f5;
  min-height: 100vh;
}

/* 页面头部 */
.page-header {
  background-color: #fff;
  padding: 16px;
  border-bottom: 1px solid #e8e8e8;
  position: sticky;
  top: 0;
  z-index: 10;
}

.header-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16px;
}

.page-title {
  font-size: 24px;
  font-weight: 600;
  color: #333;
}

.publish-btn {
  padding: 6px 16px;
  background-color: #FF6B6B;
  color: #fff;
  border: none;
  border-radius: 4px;
  font-size: 12px;
  font-weight: 500;
  height: auto;
  line-height: 1;
}

/* 筛选标签 */
.filter-tabs {
  display: flex;
  gap: 12px;
  overflow-x: auto;
  padding-bottom: 4px;
}

.filter-tab {
  flex-shrink: 0;
  padding: 6px 12px;
  border-radius: 16px;
  background-color: #f0f0f0;
  color: #666;
  font-size: 13px;
  font-weight: 500;
  transition: all 0.2s;
}

.filter-tab.active {
  background-color: #FF6B6B;
  color: #fff;
}

/* 加载状态 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 60vh;
  gap: 16px;
}

.loading-spinner {
  width: 40px;
  height: 40px;
  border: 3px solid #f0f0f0;
  border-top-color: #FF6B6B;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  font-size: 14px;
  color: #999;
}

/* 动态容器 */
.moments-container {
  padding: 12px 0;
}

/* 动态卡片 */
.moment-card {
  background-color: #fff;
  margin: 12px 12px;
  border-radius: 12px;
  padding: 16px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
}

/* 动态头部 */
.moment-header {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 12px;
}

.user-avatar {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  object-fit: cover;
}

.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.user-name {
  font-size: 14px;
  font-weight: 600;
  color: #333;
}

.moment-time {
  font-size: 12px;
  color: #999;
}

.moment-menu {
  font-size: 18px;
  color: #999;
  padding: 4px 8px;
}

/* 动态内容 */
.moment-content {
  margin-bottom: 12px;
}

.moment-text {
  font-size: 14px;
  color: #333;
  line-height: 1.6;
  display: block;
}

/* 媒体内容 */
.moment-media {
  margin-bottom: 12px;
  border-radius: 8px;
  overflow: hidden;
}

.media-single {
  width: 100%;
  max-height: 400px;
}

.media-single image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.media-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 4px;
}

.media-item {
  aspect-ratio: 1;
  overflow: hidden;
  border-radius: 4px;
}

.media-item image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

/* 宠物标签 */
.pet-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  margin-bottom: 12px;
}

.pet-tag {
  display: inline-block;
  padding: 4px 8px;
  background-color: #f0f0f0;
  border-radius: 12px;
  font-size: 12px;
  color: #666;
}

/* 位置信息 */
.moment-location {
  display: flex;
  align-items: center;
  gap: 4px;
  font-size: 12px;
  color: #999;
  margin-bottom: 12px;
}

.location-icon {
  font-size: 12px;
}

.location-text {
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 互动信息 */
.moment-stats {
  display: flex;
  gap: 16px;
  padding: 12px 0;
  border-top: 1px solid #f0f0f0;
  border-bottom: 1px solid #f0f0f0;
  margin-bottom: 12px;
  font-size: 12px;
  color: #999;
}

.stat-item {
  display: flex;
  align-items: center;
  gap: 4px;
}

/* 操作按钮 */
.moment-actions {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 8px;
}

.action-btn {
  padding: 8px 12px;
  background-color: #f9f9f9;
  border: 1px solid #e8e8e8;
  border-radius: 6px;
  font-size: 12px;
  font-weight: 500;
  color: #666;
  transition: all 0.2s;
  height: auto;
  line-height: 1;
}

.action-btn:active {
  background-color: #f0f0f0;
}

.action-btn.liked {
  background-color: #FF6B6B;
  border-color: #FF6B6B;
  color: #fff;
}

/* 加载更多 */
.load-more {
  display: flex;
  justify-content: center;
  padding: 20px 16px;
}

.load-more-btn {
  padding: 10px 32px;
  background-color: #fff;
  border: 1px solid #e8e8e8;
  border-radius: 6px;
  font-size: 14px;
  font-weight: 500;
  color: #666;
  height: auto;
  line-height: 1;
}

/* 没有更多 */
.no-more {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 20px 16px;
  color: #999;
  font-size: 12px;
}

/* 空状态 */
.empty-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 60vh;
  gap: 12px;
}

.empty-icon {
  font-size: 64px;
  margin-bottom: 16px;
}

.empty-text {
  font-size: 16px;
  font-weight: 600;
  color: #333;
}

.empty-subtitle {
  font-size: 13px;
  color: #999;
  margin-bottom: 16px;
}

/* 按钮 */
.btn {
  padding: 12px 32px;
  border: none;
  border-radius: 6px;
  font-size: 14px;
  font-weight: 500;
  transition: all 0.2s;
}

.btn-primary {
  background-color: #FF6B6B;
  color: #fff;
}

.btn-primary:active {
  opacity: 0.8;
}
