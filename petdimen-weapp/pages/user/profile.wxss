.page {
  background-color: #f5f5f5;
  min-height: 100vh;
}

/* 用户头部 */
.user-header {
  background: linear-gradient(135deg, #FF6B6B, #FF8E8E);
  padding: 24px 16px;
  display: flex;
  align-items: center;
  gap: 16px;
  color: #fff;
}

.user-avatar {
  width: 80px;
  height: 80px;
  border-radius: 50%;
  object-fit: cover;
  border: 3px solid #fff;
}

.user-details {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.user-name {
  font-size: 18px;
  font-weight: 600;
  color: #fff;
}

.user-id {
  font-size: 12px;
  color: rgba(255, 255, 255, 0.8);
}

.edit-btn {
  padding: 6px 16px;
  background-color: rgba(255, 255, 255, 0.2);
  border: 1px solid rgba(255, 255, 255, 0.5);
  color: #fff;
  border-radius: 4px;
  font-size: 12px;
  font-weight: 500;
  height: auto;
  line-height: 1;
}

/* 统计信息 */
.stats-section {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 0;
  background-color: #fff;
  margin: 12px;
  border-radius: 12px;
  overflow: hidden;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 16px 12px;
  border-right: 1px solid #f0f0f0;
}

.stat-item:last-child {
  border-right: none;
}

.stat-value {
  font-size: 18px;
  font-weight: 600;
  color: #FF6B6B;
  margin-bottom: 4px;
}

.stat-label {
  font-size: 12px;
  color: #999;
}

/* 个人简介 */
.bio-section {
  background-color: #fff;
  margin: 12px;
  border-radius: 12px;
  padding: 16px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
}

.bio-text {
  font-size: 14px;
  color: #333;
  line-height: 1.6;
  display: block;
}

/* 菜单区 */
.menu-section {
  background-color: #fff;
  margin: 12px;
  border-radius: 12px;
  overflow: hidden;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 16px;
  border-bottom: 1px solid #f0f0f0;
  gap: 12px;
  transition: all 0.2s;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background-color: #f9f9f9;
}

.menu-icon {
  font-size: 24px;
  flex-shrink: 0;
}

.menu-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.menu-title {
  font-size: 14px;
  font-weight: 600;
  color: #333;
}

.menu-subtitle {
  font-size: 12px;
  color: #999;
}

.menu-arrow {
  font-size: 16px;
  color: #999;
  flex-shrink: 0;
}

/* 登出按钮 */
.logout-section {
  padding: 24px 16px;
}

.logout-btn {
  width: 100%;
  padding: 12px 16px;
  background-color: #FF6B6B;
  color: #fff;
  border: none;
  border-radius: 6px;
  font-size: 14px;
  font-weight: 500;
  height: auto;
  line-height: 1;
}

.logout-btn:active {
  opacity: 0.8;
}
