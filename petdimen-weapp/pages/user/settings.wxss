.page {
  background-color: #f5f5f5;
  min-height: 100vh;
}

.container {
  padding: 16px;
}

/* 页面头部 */
.page-header {
  margin-bottom: 24px;
}

.page-title {
  display: block;
  font-size: 24px;
  font-weight: 600;
  color: #333;
}

/* 区域 */
.section {
  background-color: #fff;
  border-radius: 12px;
  padding: 16px;
  margin-bottom: 16px;
}

.section-title {
  display: block;
  font-size: 14px;
  font-weight: 600;
  color: #333;
  margin-bottom: 16px;
}

/* 设置项 */
.setting-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12px 0;
  border-bottom: 1px solid #f0f0f0;
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-label {
  font-size: 14px;
  font-weight: 500;
  color: #333;
}

.setting-value {
  flex: 1;
  margin-left: 16px;
}

.setting-input {
  width: 100%;
  padding: 8px 0;
  border: none;
  border-bottom: 1px solid #e8e8e8;
  font-size: 14px;
  color: #333;
  background-color: transparent;
  text-align: right;
}

.setting-input:focus {
  border-bottom-color: #FF6B6B;
  outline: none;
}

.setting-textarea {
  width: 100%;
  padding: 8px;
  border: 1px solid #e8e8e8;
  border-radius: 6px;
  font-size: 13px;
  color: #333;
  background-color: #f9f9f9;
  min-height: 80px;
  box-sizing: border-box;
}

.setting-textarea:focus {
  border-color: #FF6B6B;
  outline: none;
}

.setting-value-text {
  font-size: 14px;
  color: #999;
}

.setting-arrow {
  font-size: 16px;
  color: #999;
  margin-left: 8px;
}

/* 选择器 */
.picker-input {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8px 0;
  border-bottom: 1px solid #e8e8e8;
  font-size: 14px;
  color: #333;
}

.picker-arrow {
  font-size: 16px;
  color: #999;
}

/* 开关 */
.setting-switch {
  transform: scale(0.8);
  transform-origin: right center;
}

/* 按钮 */
.actions {
  display: flex;
  flex-direction: column;
  gap: 12px;
  margin-top: 24px;
}

.btn {
  padding: 12px 16px;
  border: none;
  border-radius: 6px;
  font-size: 14px;
  font-weight: 500;
  transition: all 0.2s;
}

.btn-primary {
  background-color: #FF6B6B;
  color: #fff;
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-primary:active {
  opacity: 0.8;
}
