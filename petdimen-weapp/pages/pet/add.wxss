.page {
  background-color: #f5f5f5;
  min-height: 100vh;
}

.container {
  padding: 16px;
}

/* 页面头部 */
.page-header {
  margin-bottom: 24px;
}

.page-title {
  display: block;
  font-size: 24px;
  font-weight: 600;
  color: #333;
  margin-bottom: 4px;
}

.page-subtitle {
  display: block;
  font-size: 13px;
  color: #999;
}

/* 表单区域 */
.form-section {
  background-color: #fff;
  border-radius: 12px;
  padding: 16px;
  margin-bottom: 16px;
}

.form-section-title {
  display: block;
  font-size: 14px;
  font-weight: 600;
  color: #333;
  margin-bottom: 16px;
}

/* 头像上传 */
.avatar-upload {
  width: 100%;
  height: 200px;
  border-radius: 12px;
  background-color: #f5f5f5;
  border: 2px dashed #e8e8e8;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  transition: all 0.2s;
}

.avatar-upload:active {
  background-color: #f0f0f0;
  border-color: #FF6B6B;
}

.avatar-upload image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.avatar-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8px;
}

.avatar-icon {
  font-size: 40px;
}

.avatar-text {
  font-size: 13px;
  color: #999;
}

/* 表单组 */
.form-group {
  margin-bottom: 16px;
}

.form-group:last-child {
  margin-bottom: 0;
}

.form-label {
  display: block;
  font-size: 14px;
  font-weight: 500;
  color: #333;
  margin-bottom: 8px;
}

.required {
  color: #FF6B6B;
}

.form-input {
  width: 100%;
  padding: 10px 12px;
  border: 1px solid #e8e8e8;
  border-radius: 6px;
  font-size: 14px;
  color: #333;
  background-color: #fff;
  box-sizing: border-box;
}

.form-input:focus {
  border-color: #FF6B6B;
  outline: none;
}

.form-input::placeholder {
  color: #999;
}

.form-textarea {
  width: 100%;
  padding: 10px 12px;
  border: 1px solid #e8e8e8;
  border-radius: 6px;
  font-size: 14px;
  color: #333;
  background-color: #fff;
  min-height: 100px;
  box-sizing: border-box;
  resize: vertical;
}

.form-textarea:focus {
  border-color: #FF6B6B;
  outline: none;
}

.form-textarea::placeholder {
  color: #999;
}

.textarea-count {
  font-size: 12px;
  color: #999;
  text-align: right;
  margin-top: 4px;
}

/* 选择器 */
.picker-input {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 10px 12px;
  border: 1px solid #e8e8e8;
  border-radius: 6px;
  background-color: #fff;
}

.picker-text {
  font-size: 14px;
  color: #333;
  flex: 1;
}

.picker-text.placeholder {
  color: #999;
}

.picker-arrow {
  font-size: 16px;
  color: #999;
  margin-left: 8px;
}

/* 单选框 */
.radio-group {
  display: flex;
  gap: 16px;
  padding: 10px 0;
}

.radio-item {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 14px;
  color: #333;
}

radio {
  width: 18px;
  height: 18px;
}

/* 标签 */
.tags-container {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.tag-item {
  display: inline-flex;
  align-items: center;
  padding: 8px 12px;
  border: 1px solid #e8e8e8;
  border-radius: 6px;
  font-size: 13px;
  color: #666;
  background-color: #f9f9f9;
  transition: all 0.2s;
}

.tag-item:active {
  background-color: #f0f0f0;
}

.tag-item.selected {
  background-color: #FF6B6B;
  color: #fff;
  border-color: #FF6B6B;
}

/* 按钮 */
.form-actions {
  display: flex;
  flex-direction: column;
  gap: 12px;
  margin-top: 24px;
}

.btn {
  padding: 12px 16px;
  border: none;
  border-radius: 6px;
  font-size: 14px;
  font-weight: 500;
  transition: all 0.2s;
}

.btn-primary {
  background-color: #FF6B6B;
  color: #fff;
}

.btn-primary:active {
  opacity: 0.8;
}

.btn-outline {
  background-color: #fff;
  border: 1px solid #e8e8e8;
  color: #333;
}

.btn-outline:active {
  background-color: #f5f5f5;
}

.btn-block {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}
